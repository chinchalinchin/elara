graph TD
    %% =========================================
    %% PALETTES & STYLES 
    %% =========================================
    %% ======================== ELDER BRANCH
    classDef elder1 fill:#311B92,stroke:#000,stroke-width:2px,color:#fff
    classDef elder2 fill:#4527A0,stroke:#000,stroke-width:2px,color:#fff
    classDef elder3 fill:#512DA8,stroke:#000,stroke-width:2px,color:#fff
    classDef elder4 fill:#5E35B1,stroke:#000,stroke-width:2px,color:#fff
    classDef elder5 fill:#673AB7,stroke:#000,stroke-width:2px,color:#fff
    classDef elder6 fill:#7E57C2,stroke:#000,stroke-width:2px,color:#fff
    %% ======================== DUTCH BRANCH
    classDef dutch1 fill:#283593,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef dutch2 fill:#303F9F,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef dutch3 fill:#3949AB,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef dutch4 fill:#3F51B5,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef dutch5 fill:#5C6BC0,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    %% ======================== CONNECTIONS
    classDef external fill:#FFF8E1,stroke:#F57C00,stroke-width:1px,color:#000
    classDef plebianEnter fill:#4A1A2C,stroke:#000,stroke-width:2px,color:#fff
    classDef equestrianExit fill:#880E4F,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef patricianExit fill:#7E57C2,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef plebianExit fill:#290916,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef dodonicExit fill:#1A237E,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef sibyllineExit fill:#0D47A1,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef chthonicExit fill:#1565C0,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef trophonianExit fill:#1976D2,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
    classDef delphicExit fill:#0288D1,stroke:#000,stroke-width:2px,color:#fff,stroke-dasharray: 5 5

    %% =========================================
    %% GEN 1: The First Patroon
    %% =========================================
    K1((Kiliaen van Rensselaer<br>1586-1643<br>1st Patroon)):::elder1
    W1_1{Hillegond van Bijler<br>1598-1626}:::elder1
    W1_2{Anna van Wely<br>1601-1670}:::elder1

    K1 ---|m. 1616| W1_1
    K1 ---|m. 1627| W1_2

    W1_1 --x S1_1[Johannes van Rensselaer<br>1625-1663<br>2nd Patroon]:::elder2

    W1_2 --o S1_2([Johannes van Rensselaer<br>1625-1663]):::dutch1

    W1_2 --x S1_3[Jan Baptist van Rensselaer<br>1629-1678<br>Director of Rensselaerswyck]:::elder2
    W1_2 --> S1_4{{Jeremias van Rensselaer<br>1632-1674<br>Acting Patroon<br>3rd Director}}:::elder2
    W1_2 --x S1_5[Rev. Nicolaas van Rensselaer<br>1636-1678<br>Heresy Trial Defendant]:::elder2
    
    %% EXPANSION: Ryckert's Line (UPDATED)
    W1_2 --> S1_6[Ryckert van Rensselaer<br>1639-1692<br>Magistrate of Albany]:::elder2
    
    %% EXPANSION: Daughters of Kiliaen
    W1_2 --> S1_7{Hillegonda van Rensselaer<br>1628-?}:::elder2
    W1_2 --> S1_8{Eleonora van Rensselaer<br>1630-?}:::elder2
    W1_2 --> S1_9{Susanna van Rensselaer<br>1634-?}:::elder2

    %% =========================================
    %% GEN 2: The American Transition & Dutch Return
    %% =========================================
    W1_2B{Elizabeth van Twiller}:::dutch1
    S1_2 -.-|m. 1655| W1_2B
    W1_2B --o S2_D1([Kiliaen van Rensselaer<br>1655-1687]):::dutch2

    W2_1{Maria van Cortlandt<br>1645-1689}:::elder2
    S1_4 ---|m. 1662| W2_1

    W2_1 --> S2_1{{Kiliaen van Rensselaer<br>1663-1719<br>4th Patroon<br>1st Lord of the Manor}}:::elder3
    W2_1 --> S2_4{Anna van Rensselaer<br>1665-1723}:::elder3
    
    W2_1 --> S2_5{Maria van Rensselaer<br>1673-1713}:::elder3
    S2_5 --> EXIT_DOD[[Descendants of Maria<br>SEE DODONIC BRANCH]]:::dodonicExit
    
    W2_1 --> S2_3[Hendrick van Rensselaer<br>1667-1740]:::elder3
    S2_3 --> EXIT_PLEB[[Descendants of Hendrick <br>SEE PLEBIAN BRANCH]]:::plebianExit

    W2_RYC{Anna van Beaumont}:::external
    S1_6 --- W2_RYC
    W2_RYC --> S2_RYC1[Kiliaen van Rensselaer<br>1670-?]:::elder3

    FAM_JDC[Jan de la Court]:::external
    S1_9 ---|m. 1654| FAM_JDC

    %% =========================================
    %% GEN 3: The Consolidation
    %% =========================================
    S2_4 -.-|m. 1686| S2_D1
    S2_D1 --o S3_D1([Kiliaen van Rensselaer<br>1686-1762]):::dutch3

    W3_1{Maria van Cortlandt<br>1674-1752}:::elder3
    S2_1 -.-|m. 1701| W3_1

    W3_1 --x S3_1{{Jeremias van Rensselaer<br>1705-1745<br>5th Patroon}}:::elder4
    W3_1 --> S3_2{{Stephen van Rensselaer I<br>1707-1747<br>6th Patroon}}:::elder4

    W3_1 --> S3_3{Maria van Rensselaer<br>1702-c. 1723}:::elder4
    S3_3 --> EXIT_SIB[[Descendants of Maria<br>SEE SIBYLLINE BRANCH]]:::sibyllineExit

    W3_1 --> S3_4{Gertruy van Rensselaer<br>1714-?}:::elder4
    S3_4 --> EXIT_CHT[[Descendants of Gertruy<br>SEE CHTHONIC BRANCH]]:::chthonicExit

    %% =========================================
    %% GEN 4: The Manor Established
    %% =========================================
    W3_DB{Maria Pasques<br>de Chavonnes}:::dutch3
    S3_D1 -.-|m. 1718| W3_DB
    W3_DB --o S4_D1([Jan Baptist van Rensselaer<br>1718-1790]):::dutch4

    W4_1{Elizabeth Groesbeck<br>1707-1756}:::elder4
    S3_2 ---|m. 1729| W4_1

    W4_1 --> S4_1{{Stephen van Rensselaer II<br>1742-1769<br>7th Patroon}}:::elder5

    W4_1 --> S4_3{Elizabeth van Rensselaer<br>1734-1813}:::elder5
    S4_3 --> EXIT_TRO[[Descendants of Elizabeth<br>SEE TROPHONIAN BRANCH]]:::trophonianExit

    %% =========================================
    %% GEN 5: The Last Patroon & The Mayor
    %% =========================================
    W4_DB2{Jacoba Elisabeth Brijnen}:::dutch4
    S4_D1 -.- W4_DB2
    W4_DB2 --x S5_D1([Jeremias van Rensselaer<br>1761-1819<br>Last Dutch Patroon]):::dutch5

    W5_1{Catherine Livingston<br>1745-1810}:::elder5
    S4_1 ---|m. 1764| W5_1

    W5_1 --> S5_1{{Stephen van Rensselaer III<br>1764-1839<br>8th Patroon<br>Lt. Governor of NY<br>Founder of RPI}}:::elder6
    W5_1 --x S5_2[Philip S. van Rensselaer<br>1767-1824<br>Mayor of Albany<br>Pres. Bank of Albany]:::elder5
    W5_1 --> S5_3{Elizabeth van Rensselaer<br>1768-1841}:::elder5

    ENTER_PLEB(((Ann van Rensselaer<br>SEE PLEBIAN BRANCH))):::plebianEnter
    S5_2 -.-|m. 1787| ENTER_PLEB

    FAM_JBS[John Bradstreet<br>Schuyler]:::external
    FAM_SCH[Peter Schuyler<br>1657-1724<br>Acting Governor of NY]:::external
    
    S2_5 ---|m. 1691| FAM_SCH

    S5_3 --- FAM_JBS
    S5_3 --> LINK_DEL[[Descendants of Elizabeth<br>SEE DELPHIC BRANCH]]:::delphicExit

    %% =========================================
    %% MAIN MALE BRANCHES
    %% =========================================
    S5_1 --> EXIT_PAT[[Descendants of Margarita Schuyler<br>SEE PATRICIAN BRANCH]]:::patricianExit
    S5_1 --> EXIT_EQU[[Descendants of Cornelia Paterson<br>SEE EQUESTRIAN BRANCH]]:::equestrianExit

